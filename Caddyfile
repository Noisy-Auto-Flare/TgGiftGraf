{
    # Глобальные настройки
    email admin@example.com
}

your-domain.com {
    # Путь к статическим файлам внутри контейнера
    root * /app/static
    file_server

    # Проксирование API запросов на сервис 'api' в Docker сети
    handle_path /api/* {
        reverse_proxy api:8000
    }

    # Логирование
    log {
        output file /var/log/caddy/giftgraph.log
    }

    # Сжатие
    encode gzip
}
