# Telegram API credentials (получить на https://my.telegram.org)
API_ID=123456
API_HASH=abcdef1234567890abcdef1234567890

# Название файла сессии Telethon (создастся в корне проекта)
SESSION_NAME=gift_crawler

# Начальные точки входа (username пользователей)
START_USERNAMES=durov,telegram

# Публичные чаты/каналы для сбора участников (username без @)
TARGET_CHATS=telegram,durov_channel

# Путь к базе данных SQLite
DB_PATH=gifts.db

# Настройки краулера (в секундах)
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=5

# Как часто проверять новые чаты и пополнять очередь (в минутах)
CHAT_SCAN_INTERVAL=120

# Через сколько дней перепроверять пользователя на наличие новых подарков
RESCAN_THRESHOLD_DAYS=7

# Максимальный размер очереди краулера
MAX_CRAWL_QUEUE_SIZE=50000

# Режим однократного запуска (true/false)
# Если true, краулер обработает очередь и выйдет
CRAWL_SINGLE_RUN=false
